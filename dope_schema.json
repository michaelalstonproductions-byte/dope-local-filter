{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dope-content-decision-v0.4",
  "title": "DOPE v0.4 Content Decision",
  "description": "Schema for raw classifier decisions. Policy engine results wrap this decision with profile, explanation, recommendation, daily-plan, audit, and optional session-memory metadata.",
  "type": "object",
  "required": [
    "score",
    "confidence",
    "category",
    "labels",
    "action",
    "reason",
    "evidence",
    "positive_replacement"
  ],
  "properties": {
    "score": {"type": "integer", "minimum": 0, "maximum": 100},
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Transparent heuristic confidence, not a learned probability."
    },
    "category": {
      "type": "string",
      "enum": ["UPLIFT", "NEUTRAL", "TOXIC", "RAGEBAIT", "DOOMSCROLL", "SHAME", "VIOLENCE", "SEXUALIZED", "SCAM"]
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "UPLIFT",
          "NEUTRAL",
          "TOXIC",
          "RAGEBAIT",
          "DOOMSCROLL",
          "SHAME",
          "VIOLENCE",
          "SEXUALIZED",
          "SCAM",
          "CONSTRUCTIVE_NEWS",
          "HARD_NEWS",
          "POSITIVE_HISTORY",
          "CIVIC_AWARENESS"
        ]
      }
    },
    "action": {"type": "string", "enum": ["ALLOW", "SOFT_WARN", "BLUR", "BLOCK", "REPLACE"]},
    "reason": {"type": "string", "minLength": 1},
    "evidence": {
      "type": "object",
      "required": ["matched_phrases", "matched_tokens", "category_scores"],
      "properties": {
        "matched_phrases": {"type": "array", "items": {"type": "string"}},
        "matched_tokens": {"type": "array", "items": {"type": "string"}},
        "category_scores": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}}
      },
      "additionalProperties": false
    },
    "positive_replacement": {"type": "string"}
  },
  "policy_output": {
    "required": ["index", "content", "decision", "profile_used", "explanation", "replacement_source", "audit_status", "audit_path"],
    "optional": ["replacement_explanation", "session_summary"]
  },
  "audit_record": {
    "required": ["ts", "index", "content", "decision", "controls", "profile", "explanation", "validation_error", "local_first", "dark_patterns", "dope_version"]
  },
  "related_outputs": [
    "dope_recommendation_schema.json"
  ],
  "additionalProperties": false
}
