{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dope-content-decision-v0.2",
  "title": "DOPE v0.2 Content Decision",
  "description": "Schema for raw classifier decisions. Policy engine results wrap this decision with index, content, audit_status, and audit_path.",
  "type": "object",
  "required": [
    "score",
    "confidence",
    "category",
    "labels",
    "action",
    "reason",
    "evidence",
    "positive_replacement"
  ],
  "properties": {
    "score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "category": {
      "type": "string",
      "enum": ["UPLIFT", "NEUTRAL", "TOXIC", "RAGEBAIT", "DOOMSCROLL", "SHAME", "VIOLENCE", "SEXUALIZED", "SCAM"]
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["UPLIFT", "NEUTRAL", "TOXIC", "RAGEBAIT", "DOOMSCROLL", "SHAME", "VIOLENCE", "SEXUALIZED", "SCAM"]
      }
    },
    "action": {
      "type": "string",
      "enum": ["ALLOW", "SOFT_WARN", "BLUR", "BLOCK", "REPLACE"]
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "object",
      "required": ["matched_phrases", "matched_tokens", "category_scores"],
      "properties": {
        "matched_phrases": {
          "type": "array",
          "items": {"type": "string"}
        },
        "matched_tokens": {
          "type": "array",
          "items": {"type": "string"}
        },
        "category_scores": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "additionalProperties": false
    },
    "positive_replacement": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
